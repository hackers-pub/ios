"""
Discriminant used to filter a connection to a single post type. This enum does not appear on the `Post` interface itself; use __typename` or inline fragments to distinguish concrete types.
"""
enum PostType {
  """
  Long-form article with a title, year-based slug URL, and optional multi-language translations.
  """
  ARTICLE

  """
  Short microblog post (equivalent to a Mastodon Status or ActivityPub Note).
  """
  NOTE

  """
  ActivityPub Question (poll) originating from a federated instance. Creating new Questions locally is not supported.
  """
  QUESTION
}

"""
Controls who can see a post and whether it appears in timelines. Visibility is set at creation time and cannot be changed for posts that have already been federated to remote instances.
"""
enum PostVisibility {
  """
  Visible only to explicitly @-mentioned actors — the closest equivalent to a direct message. Not delivered to followers who were not mentioned.
  """
  DIRECT

  """
  Visible only to the actor's approved followers. Never appears in any public timeline. Federated only to follower inboxes.
  """
  FOLLOWERS

  """
  Not visible to anyone other than the author. Used internally for soft-deleted or administratively hidden posts; do not set this value when creating posts.
  """
  NONE

  """
  Visible to everyone including unauthenticated visitors. Appears in the public timeline and the actor's public post list. Federated to all known instances.
  """
  PUBLIC

  """
  Accessible via direct link but excluded from the public timeline. Use for posts that should be reachable without being broadcast widely.
  """
  UNLISTED
}

"""
Publish an article draft, converting it to a live `Article` post and deleting the draft. Sends an ActivityPub `Create` activity. Requires authentication.
"""
input PublishArticleDraftInput {
  allowLlmTranslation: Boolean
  clientMutationId: ID
  id: ID!
  language: Locale!
  quotePolicy: QuotePolicy
  slug: String!
}

type PublishArticleDraftPayload {
  article: Article!
  clientMutationId: ID
  deletedDraftId: ID!
}

union PublishArticleDraftResult = InvalidInputError | NotAuthenticatedError | PublishArticleDraftPayload

"""
Controls how much post content may be included in push notification payloads. Payloads can be displayed on a lock screen and pass through third-party push services.
"""
enum PushNotificationPreviewPolicy {
  """
  Include a short preview whenever the notification has post content, including restricted or sensitive posts.
  """
  ALL

  """Never include post content previews in push notification payloads."""
  NONE

  """
  Include a short preview only for non-sensitive `PUBLIC` or `UNLISTED` posts. Other notifications use generic copy.
  """
  PUBLIC_ONLY
}

"""
Push delivery service for a registered notification target. Use `WEB_PUSH` for browser Push API subscriptions.
"""
enum PushNotificationService {
  """Apple Push Notification service target used by iOS clients."""
  APNS

  """Firebase Cloud Messaging target used by Android clients."""
  FCM

  """Browser Push API subscription delivered with the Web Push protocol."""
  WEB_PUSH
}

type Query {
  """
  Look up a local account by its username (without the `@host` suffix). Returns `null` when no account with that username exists.
  """
  accountByUsername(username: String!): Account

  """
  All local accounts. Intended for internal tooling; prefer `adminAccounts` for paginated moderator views.
  """
  accounts: [Account!]!

  """
  Look up an actor by their fediverse handle (e.g., `@alice@mastodon.social` or `alice@hackers.pub`). For `user@host` handles not already in the local cache, triggers an outbound WebFinger + ActivityPub fetch and persists the result; this only happens for authenticated requests, since unauthenticated callers are not allowed to spawn outbound federation lookups.
  """
  actorByHandle(
    """Whether to allow local handles (e.g. @username)."""
    allowLocalHandle: Boolean = false
    handle: String!
  ): Actor

  """
  Look up an actor by their profile URL, resolving via ActivityPub when necessary. Only authenticated requests trigger outbound federation lookups; unauthenticated callers receive only cached results.
  """
  actorByUrl(url: URL!): Actor

  """
  Look up an actor by their internal row UUID (`Actor.uuid`). Prefer `actorByHandle` for user-facing lookups; this is mainly for internal cross-references where a UUID is already known.
  """
  actorByUuid(uuid: UUID!): Actor

  """
  Moderator-only connection of every account.  Returns null when the viewer is not a moderator; routes should guard with `viewer.moderator` and redirect non-moderators.
  """
  adminAccounts(after: String, before: String, first: Int, last: Int, orderBy: AdminAccountOrderBy, orderDirection: OrderDirection, search: String): AdminAccountConnection

  """
  Look up a locally-authored article by the author's handle, publication year, and URL slug. This is the resolver for the canonical article permalink path `/@{handle}/{year}/{slug}`.
  """
  articleByYearAndSlug(handle: String!, idOrYear: String!, slug: String!): Article

  """
  Look up an article draft by its global `id` or its `uuid`. Requires authentication; only returns drafts owned by the authenticated viewer.
  """
  articleDraft(id: ID, uuid: UUID): ArticleDraft
  availableLocales: [Locale!]!

  """
  The authenticated viewer's bookmarked posts, newest-bookmarked first. Throws `AUTHENTICATION_REQUIRED` when called without a session.
  """
  bookmarks(after: String, before: String, first: Int, last: Int, postType: PostType): QueryBookmarksConnection!
  codeOfConduct(
    """The locale for the Code of Conduct."""
    locale: Locale!
  ): Document!

  """
  Look up a known fediverse instance by its host name. Returns `null` if this instance has not been discovered yet.
  """
  instanceByHost(host: String!): Instance

  """
  Look up a specific invitation link by its UUID and the inviter's username. Returns `null` if the link does not exist or the `username` does not match the link's owner (prevents link enumeration).
  """
  invitationLink(id: UUID!, username: String!): InvitationLink

  """
  Moderator-only invitation-regeneration preview.  Returns null when the viewer is not a moderator; the route guards with `viewer.moderator` to redirect non-moderators.
  """
  invitationRegenerationStatus: InvitationRegenerationStatus

  """Returns all accounts as a flat array for building the invitation tree."""
  invitationTree: [InvitationTreeNode!]!

  """
  Look up a remote Fediverse user by their handle, fetching their ActivityPub profile and constructing a remote follow URL for the given actor.
  """
  lookupRemoteFollower(
    """The Relay global ID of the Hackers' Pub actor to be followed."""
    actorId: ID!

    """
    The Fediverse handle of the remote user who wants to follow (e.g., @user@mastodon.social).
    """
    followerHandle: String!
  ): WebFingerResult
  markdownGuide(
    """The locale for the Markdown guide."""
    locale: Locale!
  ): Document!

  """
  Moderator-only list of news feed exclusion patterns, newest first.  `null` for non-moderators.
  """
  newsExcludedPatterns: [NewsExcludedPattern!]

  """
  Moderator-only list of news links currently carrying a score penalty, heaviest first, for reviewing/clearing demotions (a buried link is no longer near the top of the feed).  `null` for non-moderators.
  """
  newsPenalizedStories: [PostLink!]

  """
  Moderator-only news scoring snapshot.  Returns `null` when the viewer is not a moderator; routes should guard with `viewer.moderator`.
  """
  newsScoreStatus: NewsScoreStatus

  """
  Links shared across the fediverse, ranked as a news feed.  Forward pagination only (`first`/`after`); `last`/`before` raise a `PAGINATION_ERROR`.  Pages are capped at 100 stories.  No authentication required.
  """
  newsStories(
    after: String
    before: String
    first: Int
    last: Int

    """How to rank the feed.  Defaults to `POPULAR`."""
    order: NewsOrder = POPULAR
  ): QueryNewsStoriesConnection!

  """
  Look up a news story (a shared link) by its row UUID, for the discussion permalink `/news/{uuid}`.  Returns `null` for a malformed id, or for a link that is not a public news story: only links with a qualifying public share (`latestActivityAt` is not `null`) resolve, so a link seen only in followers-only or direct posts stays private.  A link hidden from the feed by an exclusion pattern (`excludedFromNews`) is still reachable here.
  """
  newsStory(
    """
    The link's row UUID (`PostLink.uuid`), as embedded in the `/news/{uuid}` permalink.
    """
    id: UUID!
  ): PostLink
  node(id: ID!): Node
  nodes(ids: [ID!]!): [Node]!

  """
  Moderator-only orphan media preview.  Returns null when the viewer is not a moderator.
  """
  orphanMediaStatus: OrphanMediaStatus

  """
  Posts from accounts the authenticated viewer follows, newest first. Throws `AUTHENTICATION_REQUIRED` when called without a session. Pagination window (`first`/`last`) is capped at 250 posts. Use `languages` to filter by language (a base code like `"en"` matches `"en"` and all `"en-*"` variants), `local` to restrict to this instance only, and `withoutShares` to hide boost wrappers.
  """
  personalTimeline(
    after: String
    before: String
    first: Int

    """
    Filter by base language code. Passing `"en"` returns posts with `language = "en"` or any `"en-*"` variant. Region-specific tags such as `"en-US"` are normalized to their base language and match all variants. At most 20 codes are accepted; passing more raises a `TOO_MANY_LANGUAGE_FILTERS` error.
    """
    languages: [Locale!] = []
    last: Int
    local: Boolean = false
    postType: PostType
    withoutShares: Boolean = false
  ): QueryPersonalTimelineConnection!

  """
  Resolve a post by its URL, fetching it from the originating instance via ActivityPub if it is not already cached. Requires authentication (unauthenticated callers always receive `null`). Returns `null` if the post is not found or not visible to the viewer.
  """
  postByUrl(url: String!): Post
  privacyPolicy(
    """The locale for the Privacy Policy."""
    locale: Locale!
  ): Document!

  """
  All public posts from all known instances, newest first. Accessible without authentication. Pagination window (`first`/`last`) is capped at 250 posts. Use `languages` to filter by language, `local` to restrict to this instance only, and `withoutShares` to hide boost wrappers.
  """
  publicTimeline(
    after: String
    before: String
    first: Int

    """
    Filter by base language code. Passing `"en"` returns posts with `language = "en"` or any `"en-*"` variant. Region-specific tags such as `"en-US"` are normalized to their base language and match all variants. At most 20 codes are accepted; passing more raises a `TOO_MANY_LANGUAGE_FILTERS` error.
    """
    languages: [Locale!] = []
    last: Int
    local: Boolean = false
    postType: PostType
    withoutShares: Boolean = false
  ): QueryPublicTimelineConnection!

  """
  A small curated list of suggested accounts to follow, weighted toward accounts that write in the viewer's preferred locale. Capped at 50 results.
  """
  recommendedActors(limit: Int = 10, locale: Locale): [Actor!]!

  """
  Renders a Markdown string to HTML. When `articleSourceId` is provided, `hp-medium:KEY` references in the markdown are resolved against that article source's attached media (e.g. for previewing edits to an existing article). Only the article's author may pass their own `articleSourceId`; otherwise the call is rejected.
  """
  renderMarkdown(
    """
    UUID of an `ArticleSource` owned by the viewer. When provided, the rendered HTML resolves `hp-medium:KEY` references against this source's media. The missing-medium placeholder is localized to the viewer's preferred locale.
    """
    articleSourceId: UUID

    """
    Markdown source text to render into sanitized `HTML`. Used by client-side previews while composing or editing posts.
    """
    content: String!
  ): HTML!

  """
  Prefix search for @mention autocomplete. Matches against both username and host. Requires authentication to prevent unauthenticated callers from triggering outbound federation lookups. Capped at 50 results.
  """
  searchActorsByHandle(limit: Int = 25, prefix: String!): [Actor!]!
  searchGuide(
    """The locale for the search guide."""
    locale: Locale!
  ): Document!

  """
  Look up a single actor or post by its fediverse handle (e.g., @alice@mastodon.social) or URL. Returns a local redirect URL, or null if nothing matches. For authenticated users, triggers federated WebFinger/ActivityPub lookups when the object is not already cached.
  """
  searchObject(query: String!): SearchObjectResult

  """
  Full-text post search. Supports keyword operators (see the `searchGuide` query for syntax). Only forward pagination is supported (`before`/`last` are rejected). Excludes boost wrappers; returns only original posts.
  """
  searchPost(after: String, before: String, first: Int, languages: [Locale!] = [], last: Int, query: String!): QuerySearchPostConnection!

  """
  Base language codes to show in the timeline language filter. When the viewer is authenticated and has language preferences set, returns the base codes of those locales (e.g. `ko-KR` → `ko`). Otherwise parses the `Accept-Language` request header and returns its base codes in preference order. Returns an empty list when no language information is available.
  """
  suggestedFilterLanguages: [Locale!]!

  """Verify a signup token and return the signup info if valid."""
  verifySignupToken(
    """The verification code."""
    code: String!

    """The signup token to verify."""
    token: UUID!
  ): SignupInfo

  """
  The `Account` of the currently authenticated user, or `null` when not authenticated. Use this as the entry point for all viewer-specific data (notifications, drafts, settings).
  """
  viewer: Account

  """
  URL-safe Base64 VAPID public key for browser Push API subscriptions. Returns `null` when Web Push delivery is not configured on the server.
  """
  webPushVapidPublicKey: String
}

type QueryBookmarksConnection {
  edges: [QueryBookmarksConnectionEdge!]!
  pageInfo: PageInfo!
}

type QueryBookmarksConnectionEdge {
  cursor: String!
  node: Post!
}

type QueryNewsStoriesConnection {
  edges: [QueryNewsStoriesConnectionEdge!]!
  pageInfo: PageInfo!
}

type QueryNewsStoriesConnectionEdge {
  cursor: String!
  node: PostLink!
}

type QueryPersonalTimelineConnection {
  edges: [QueryPersonalTimelineConnectionEdge!]!
  pageInfo: PageInfo!
}

type QueryPersonalTimelineConnectionEdge {
  added: DateTime!
  cursor: String!
  lastSharer: Actor
  node: Post!
  sharersCount: Int!
}

type QueryPublicTimelineConnection {
  edges: [QueryPublicTimelineConnectionEdge!]!
  pageInfo: PageInfo!
}

type QueryPublicTimelineConnectionEdge {
  """
  When this post was added to the timeline: either its publication time or when it was most recently boosted into the feed.
  """
  added: DateTime!
  cursor: String!

  """
  The most recent account the viewer follows that boosted this post into the timeline, if the post reached the viewer via a boost.
  """
  lastSharer: Actor
  node: Post!

  """
  Number of accounts the viewer follows that have boosted this post. Useful for 'N people you follow shared this' display.
  """
  sharersCount: Int!
}

type QuerySearchPostConnection {
  edges: [QuerySearchPostConnectionEdge!]!
  pageInfo: PageInfo!
}

type QuerySearchPostConnectionEdge {
  cursor: String!
  node: Post!
}

"""
An ActivityPub Question (poll) originating from a federated instance. Hackers' Pub does not support creating `Question`s locally; local users can vote on and boost remote questions only. Always use `Post.uuid` (the row PK) for internal permalinks; there is no local `sourceId`.
"""
type Question implements Node & Post & Reactable {
  actor: Actor!
  content: HTML!
  engagementStats: PostEngagementStats!

  """
  Plain-text excerpt of the post. Returns `summary` when set; otherwise falls back to the HTML content stripped of tags. For a truncated HTML preview, use `excerptHtml` instead.
  """
  excerpt: String!

  """
  A sanitized, truncated HTML preview of this post's content, clipped to roughly `maxChars` visible characters with valid tag structure preserved. Use this on feed cards instead of `content` to keep the rendered DOM small. Anchor tags are stripped — the surrounding card is expected to be the link to the full post. This does NOT fall back to `summary`; query `summary` separately when you want to display a real (e.g. LLM-generated) summary with its own affordances.
  """
  excerptHtml(maxChars: Int!): HTML!

  """
  Hashtags mentioned in the post, extracted from the post's tag map. Each entry includes the tag name and its canonical hashtag search URL.
  """
  hashtags: [Hashtag!]!
  id: ID!
  iri: URL!
  language: String

  """
  OpenGraph / oEmbed preview for the first link in the post. `null` when the post has no links or the metadata has not been fetched yet.
  """
  link: PostLink

  """
  Media attachments on this post, in display order. For federated posts the URLs point to the originating instance.
  """
  media: [PostMedium!]!

  """
  Actors explicitly @-mentioned in this post. Does not include implicit mentions (e.g., the author of the post being replied to).
  """
  mentions(after: String, before: String, first: Int, last: Int): PostMentionsConnection!

  """
  The post's title. Non-null for `Article`s; `null` for `Note`s, boost wrappers, and `Question`s.
  """
  name: String
  poll: Poll
  published: DateTime!
  quotePolicy: QuotePolicy!
  quoteTargetState: QuoteTargetState
  quotedPost: Post

  """Posts that quote this post inline."""
  quotes(after: String, before: String, first: Int, last: Int): PostQuotesConnection!
  reactionGroup(customEmojiId: ID, emoji: String): ReactionGroup
  reactionGroups: [ReactionGroup!]!

  """Posts that are direct replies to this post."""
  replies(after: String, before: String, first: Int, last: Int): PostRepliesConnection!

  """The post this post is a reply to, or `null` for top-level posts."""
  replyTarget: Post

  """
  Whether the post is marked as sensitive (NSFW). Clients should hide the content behind a content warning when this is `true`.
  """
  sensitive: Boolean!
  sharedPost: Post

  """
  Boost wrapper posts that reshare this post. Each edge represents a single boost by a specific actor.
  """
  shares(after: String, before: String, first: Int, last: Int): PostSharesConnection!

  """
  Author-provided or LLM-generated summary of the post. `null` when no summary has been set. For LLM summaries, check `ArticleContent.summary` and `summaryStarted` instead, as those are tracked per language on articles.
  """
  summary: String
  updated: DateTime!

  """
  The canonical, human-readable URL of this question, as advertised by the originating instance. Question originals are only persisted from federated remote instances, and local share wrappers copy the shared post's URL, so this never encodes a local-source identifier — do not assume any relationship between its path and `Post.uuid`.
  """
  url: URL

  """
  The post row's primary key, stable for the lifetime of the post. Question originals are only persisted from federated remote instances; local Question rows may also exist as share wrappers (boosts) when a local user reshares a remote question. Neither case carries a local source row (a DB check constraint forbids `noteSourceId` on non-Note rows), so this row PK is the right token to use when building internal permalinks for questions — though `Post.url` will still reflect whatever URL the originating instance advertised, which generally won't share this UUID.
  """
  uuid: UUID!

  """
  Whether the authenticated viewer is allowed to quote this post, based on `quotePolicy`, visibility, and block state. Always `false` for unauthenticated requests.
  """
  viewerCanQuote: Boolean!

  """
  Whether the authenticated viewer is allowed to reply to this post, based on visibility and block state. Always `false` for unauthenticated requests.
  """
  viewerCanReply: Boolean!

  """
  Whether the authenticated viewer (as the quoted post's author) can revoke a quote of their post. `true` only when the viewer is the author of `quotedPost` and the quoting post is either local or has an authorization IRI.
  """
  viewerCanRevokeQuote: Boolean!

  """
  Whether the authenticated viewer is allowed to boost this post, based on visibility and block state. Always `false` for unauthenticated requests.
  """
  viewerCanShare: Boolean!

  """
  Whether the authenticated viewer has bookmarked this post. Always `false` for unauthenticated requests.
  """
  viewerHasBookmarked: Boolean!

  """
  Whether the authenticated viewer has pinned this post to their profile. Always `false` for unauthenticated requests.
  """
  viewerHasPinned: Boolean!

  """
  Whether the authenticated viewer has boosted this post. Always `false` for unauthenticated requests.
  """
  viewerHasShared: Boolean!
  visibility: PostVisibility!
}

"""Notification that an actor quoted one of this account's posts."""
type QuoteNotification implements Node & Notification {
  account: Account!
  actors(after: String, before: String, first: Int, last: Int): NotificationActorsConnection!
  created: DateTime!
  id: ID!
  post: Post
  uuid: UUID!
}

"""
Controls who may embed this post as a quote in their own posts. Applies to both local and federated clients; cross-instance requests from restricted actors result in a `QuoteTargetState` on the quoting post.
"""
enum QuotePolicy {
  """Anyone (followers and non-followers alike) may quote."""
  EVERYONE

  """
  Only the post author's approved followers may quote. Non-followers' quote attempts are denied.
  """
  FOLLOWERS

  """
  Only the post author may quote their own post. Effectively disables quoting by others.
  """
  SELF
}

"""
The cross-instance quote-request approval status for this post when it is itself the quoting post. Only non-null while the request is outstanding or has been rejected; once approved, this field returns `null`.
"""
enum QuoteTargetState {
  """
  The quoted post's author rejected the quote request. The quote should not be displayed to viewers.
  """
  DENIED

  """
  A cross-instance quote request has been sent to the quoted post's author and is awaiting their approval.
  """
  PENDING
}

"""
Notification that the author updated a post this account previously quoted.
"""
type QuotedPostUpdatedNotification implements Node & Notification {
  account: Account!
  actors(after: String, before: String, first: Int, last: Int): NotificationActorsConnection!
  created: DateTime!
  id: ID!

  """
  The updated post. This may be `null` if the post was deleted after the notification was created.
  """
  post: Post
  uuid: UUID!
}

"""
Notification that one or more actors reacted with an emoji to one of this account's posts. The `emoji` and `customEmoji` fields identify which reaction triggered the notification.
"""
type ReactNotification implements Node & Notification {
  account: Account!
  actors(after: String, before: String, first: Int, last: Int): NotificationActorsConnection!
  created: DateTime!
  customEmoji: CustomEmoji
  emoji: String
  id: ID!
  post: Post
  uuid: UUID!
}

"""
An object that can receive emoji reactions. Implemented by `Post` types (`Note`, `Article`, `Question`).
"""
interface Reactable implements Node {
  id: ID!
  reactionGroup(customEmojiId: ID, emoji: String): ReactionGroup
  reactionGroups: [ReactionGroup!]!
}

type Reaction implements Node {
  actor: Actor!
  created: DateTime!
  data: ReactionData!
  id: ID!
  post: Post!
}

union ReactionData = CustomEmoji | StandardEmoji

interface ReactionGroup {
  reactors(after: String, before: String, first: Int, last: Int): ReactionGroupReactorsConnection!
  subject: Reactable!
}

type ReactionGroupReactorsConnection {
  edges: [ReactionGroupReactorsConnectionEdge!]!
  pageInfo: PageInfo!
  totalCount: Int!
  viewerHasReacted: Boolean!
}

type ReactionGroupReactorsConnectionEdge {
  cursor: String!
  node: Actor!
}

"""The result of a full news score recompute."""
type RecomputeNewsScoresPayload {
  """
  Number of links with at least one qualifying public share that were (re)scored by this run.  Stale links dropped from the feed (they lost their last public share) are reset to zero but not counted here.
  """
  linksUpdated: Int!

  """When the recompute ran."""
  recomputedAt: DateTime!

  """The scoring status after the run."""
  status: NewsScoreStatus!
}

union RecomputeNewsScoresResult = NotAuthenticatedError | NotAuthorizedError | RecomputeNewsScoresPayload

enum RedeemEmailError {
  EMAIL_ALREADY_TAKEN
  EMAIL_INVALID
}

union RedeemInvitationLinkResult = RedeemInvitationLinkSuccess | RedeemInvitationLinkValidationErrors

type RedeemInvitationLinkSuccess {
  email: Email!
  invitationLink: InvitationLink!
}

type RedeemInvitationLinkValidationErrors {
  email: RedeemEmailError
  emailOwner: Account
  link: RedeemLinkError
  sendFailed: Boolean
  verifyUrl: RedeemVerifyUrlError
}

enum RedeemLinkError {
  LINK_EXHAUSTED
  LINK_EXPIRED
  LINK_NOT_FOUND
}

enum RedeemVerifyUrlError {
  VERIFY_URL_INVALID_ORIGIN
  VERIFY_URL_NO_CODE
  VERIFY_URL_NO_TOKEN
}

"""The result of a successful invitations regeneration."""
type RegenerateInvitationsPayload {
  """Number of accounts whose `leftInvitations` was incremented."""
  accountsAffected: Int!

  """When the regeneration ran."""
  regenerated: DateTime!

  """When the regeneration ran."""
  regeneratedAt: DateTime! @deprecated(reason: "Use regenerated")

  """The updated regeneration status reflecting the just-recorded run."""
  status: InvitationRegenerationStatus!
}

union RegenerateInvitationsResult = NotAuthenticatedError | NotAuthorizedError | RegenerateInvitationsPayload

"""
Returned by the deprecated APNS registration mutation when the token could not be stored. New clients should use the unified push target mutation instead.
"""
type RegisterApnsDeviceTokenFailedError {
  """Maximum number of APNS device tokens this account may register."""
  limit: Int!

  """Human-readable explanation of the APNS registration failure."""
  message: String!
}

"""
Legacy input for registering an APNS device token. Use `RegisterPushNotificationTargetInput` for new clients.
"""
input RegisterApnsDeviceTokenInput {
  clientMutationId: ID

  """APNS device token. Hex tokens are normalized before storage."""
  deviceToken: String!
}

"""
Legacy APNS registration payload. New clients should read the unified `RegisterPushNotificationTargetPayload` fields instead.
"""
type RegisterApnsDeviceTokenPayload {
  clientMutationId: ID

  """When this APNS token was first registered."""
  created: DateTime!

  """Normalized APNS device token that was registered."""
  deviceToken: String!

  """When this APNS token was last refreshed."""
  updated: DateTime!
}

union RegisterApnsDeviceTokenResult = InvalidInputError | NotAuthenticatedError | RegisterApnsDeviceTokenFailedError | RegisterApnsDeviceTokenPayload

"""
Returned by the deprecated FCM registration mutation when the token could not be stored. New clients should use the unified push target mutation instead.
"""
type RegisterFcmDeviceTokenFailedError {
  """Maximum number of FCM device tokens this account may register."""
  limit: Int!

  """Human-readable explanation of the FCM registration failure."""
  message: String!
}

"""
Legacy input for registering an FCM device token. Use `RegisterPushNotificationTargetInput` for new clients.
"""
input RegisterFcmDeviceTokenInput {
  clientMutationId: ID

  """FCM registration token. Surrounding whitespace is trimmed."""
  deviceToken: String!
}

"""
Legacy FCM registration payload. New clients should read the unified `RegisterPushNotificationTargetPayload` fields instead.
"""
type RegisterFcmDeviceTokenPayload {
  clientMutationId: ID

  """When this FCM token was first registered."""
  created: DateTime!

  """Trimmed FCM registration token that was registered."""
  deviceToken: String!

  """When this FCM token was last refreshed."""
  updated: DateTime!
}

union RegisterFcmDeviceTokenResult = InvalidInputError | NotAuthenticatedError | RegisterFcmDeviceTokenFailedError | RegisterFcmDeviceTokenPayload

"""
Register or refresh a push notification target for the authenticated viewer. `APNS` and `FCM` require `token`; `WEB_PUSH` requires `endpoint`, `p256dh`, and `auth` from the browser `PushSubscription`.
"""
input RegisterPushNotificationTargetInput {
  """URL-safe Base64 `auth` secret from `PushSubscription`."""
  auth: String
  clientMutationId: ID

  """
  Browser push service endpoint from `PushSubscription.endpoint`. Required for `WEB_PUSH` and omitted otherwise.
  """
  endpoint: String

  """
  Optional browser subscription expiration time. `null` means the browser did not provide an expiration.
  """
  expirationTime: DateTime

  """URL-safe Base64 `p256dh` encryption key from `PushSubscription`."""
  p256dh: String

  """Push service that owns the target."""
  service: PushNotificationService!

  """Device token for `APNS` or `FCM`. Must be omitted for `WEB_PUSH`."""
  token: String
}

"""
Successful response for `registerPushNotificationTarget`. Contains the normalized `token` or `endpoint` that was stored.
"""
type RegisterPushNotificationTargetPayload {
  clientMutationId: ID

  """When this target was first registered."""
  created: DateTime!

  """Browser Push API endpoint. `null` for APNS and FCM targets."""
  endpoint: String

  """Push service for the registered target."""
  service: PushNotificationService!

  """`APNS` or `FCM` device token. `null` for browser Web Push targets."""
  token: String

  """When this target was last refreshed or reassigned to an account."""
  updated: DateTime!
}

"""
Result of registering a push notification target. Successful responses return the stored target; invalid input and authentication failures are returned as typed errors.
"""
union RegisterPushNotificationTargetResult = InvalidInputError | NotAuthenticatedError | RegisterPushNotificationTargetPayload

